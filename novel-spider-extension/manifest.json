{
  "manifest_version": 3,
  "name": "小说爬虫",
  "version": "1.0",
  "description": "爬取当前页面的小说并选择性保存",
  "permissions": [
    "activeTab",
    "scripting",
    "downloads"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}